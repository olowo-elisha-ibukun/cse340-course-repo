<%- include('partials/header') %>

<main id="main-content">
    <div class="container">
        <h1><%= title %></h1>

        <% if (errors && errors.length) { %>
            <div class="error-summary" role="alert" aria-live="assertive">
                <h2>There was a problem with your submission</h2>
                <ul>
                    <% errors.forEach(error => { %>
                        <li><%= error.msg %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form action="/organizations/new" method="POST" class="category-form">
            <div class="form-group">
                <label for="name">Organization Name</label>
                <input type="text" id="name" name="name" value="<%= organization.name %>" required maxlength="100" />
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="4"><%= organization.description %></textarea>
            </div>
            <div class="form-group">
                <label for="contact_email">Contact Email</label>
                <input type="email" id="contact_email" name="contact_email" value="<%= organization.contact_email %>" />
            </div>
            <div class="form-group">
                <label for="phone_number">Phone Number</label>
                <input type="text" id="phone_number" name="phone_number" value="<%= organization.phone_number %>" />
            </div>
            <div class="form-group">
                <label for="logo_filename">Logo Filename</label>
                <input type="text" id="logo_filename" name="logo_filename" value="<%= organization.logo_filename %>" />
            </div>
            <button type="submit" class="button button-primary">Create Organization</button>
        </form>
    </div>
</main>

<%- include('partials/footer') %>