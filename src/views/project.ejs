<%- include('partials/header') %>

<main id="main-content">
    <div class="container">
        <section class="page-actions">
            <div>
                <h1><%= project.title %></h1>
                <p>Review the project details and explore other categories related to this service opportunity.</p>
            </div>
        </section>

        <section class="content-panel project-detail-card">
            <% if (project.organization_name) { %>
                <p><strong>Organization:</strong> <%= project.organization_name %></p>
            <% } %>

            <% if (project.date) { %>
                <p><strong>Start Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <% } %>

            <p><%= project.description %></p>

            <section class="project-volunteer-action mt-3">
                <% if (!locals.accountData) { %>
                    <p>Please <a href="/login">log in</a> to volunteer for this service project.</p>
                <% } else { %>
                    <% if (typeof isVolunteering !== 'undefined' && isVolunteering) { %>
                        <div class="badge badge-success mb-2">✓ You are volunteering for this project!</div>
                        <form action="/project/<%= project.project_id %>/unvolunteer" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Stop Volunteering</button>
                        </form>
                    <% } else { %>
                        <form action="/project/<%= project.project_id %>/volunteer" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-success btn-sm">Volunteer for this Project</button>
                        </form>
                    <% } %>
                <% } %>
            </section>

            <section class="category-tags">
                <h2>Related Categories</h2>
                <div class="tag-badge-group">
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(function(category) { %>
                            <a href="/category/<%= category.category_id %>" class="tag-badge">
                                #<%= category.name %>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p>No related categories listed for this project.</p>
                    <% } %>
                </div>
            </section>
        </section>
    </div>
</main>

<%- include('partials/footer') %>
