<%- include('partials/header') %>

<main id="main-content" class="<%= categoryDetails.category_id === 1 ? 'category-bg-health' : (categoryDetails.category_id === 2 ? 'category-bg-education' : (categoryDetails.category_id === 3 ? 'category-bg-environment' : (categoryDetails.category_id === 4 ? 'category-bg-community' : (categoryDetails.category_id === 5 ? 'category-bg-youth' : (categoryDetails.category_id === 6 ? 'category-bg-animal' : ''))))) %>">
    <div class="container">
        <section class="page-actions">
            <div>
                <h1><%= categoryDetails.name %></h1>

                <% if (categoryDetails.description) { %>
                    <p><%= categoryDetails.description %></p>
                <% } %>
            </div>
        </section>

        <section class="project-list project-list-hero">
            <h2>Assigned Service Projects</h2>
            <% if (projects && projects.length) { %>
                <ul>
                    <% projects.forEach(project => { %>
                        <li>
                            <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p>No service projects are currently assigned to this category.</p>
            <% } %>
        </section>
    </div>
</main>

<%- include('partials/footer') %>
