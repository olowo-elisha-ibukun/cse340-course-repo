<%- include('partials/header') %>

<main id="main-content" class="categories-hero-service">
    <div class="container">
        <section class="page-actions">
            <div>
                <h1><%= title %></h1>
                <p>Explore our diverse range of service opportunities organized by category.</p>
            </div>
            <a class="button button-primary" href="/categories/add">Add New Category</a>
        </section>

        <section class="content-panel">
            <ul class="category-list">
                <% if (categories && categories.length) { %>
                <% categories.forEach(category => { %>
                    <li>
                        <h3><a href="/category/<%= category.category_id %>"><%= category.name %></a></h3>
                        <% if (category.description) { %>
                            <p><%= category.description %></p>
                        <% } else { %>
                            <p>No description available.</p>
                        <% } %>
                        <a class="category-edit-link" href="/categories/edit-category/<%= category.category_id %>">Edit</a>
                    </li>
                <% }) %>
            <% } else { %>
                <li>
                    <h3>No categories available</h3>
                    <p>Please check back later or load the database.</p>
                </li>
            <% } %>
        </ul>
        </section>
    </div>
</main>

<%- include('partials/footer') %>
